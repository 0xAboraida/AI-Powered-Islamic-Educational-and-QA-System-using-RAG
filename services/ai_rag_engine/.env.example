# ========================================================
# ==================== RAG PIPELINE ======================
# ========================================================
# Qdrant Primary Instance
QDRANT_URL="https://your-qdrant-cluster-url.cloud.qdrant.io"
QDRANT_API_KEY="your-qdrant-api-key"

# Qdrant Second Instance
QDRANT_URL2="https://your-second-qdrant-cluster-url.cloud.qdrant.io:6333"
QDRANT_API_KEY2="your-second-qdrant-api-key"

# MongoDB Clusters (Replace with your actual MongoDB connection strings)
MONGO_URI_FIQH_HANBALI_HANAFI_CLUSTER1="mongodb+srv://user:password@cluster.mongodb.net/?appName=appName"
MONGO_URI_FIQH_SHAFII_MALIKI_CLUSTER2=""
MONGO_URI_AQEEDAH_CLUSTER3=""
MONGO_URI_TAFSEER_CLUSTER4=""
MONGO_URI_SEERAH_CLUSTER5=""
MONGO_URI_TARIKH_CLUSTER6=""
MONGO_URI_TARIKH_CLUSTER7=""
MONGO_URI_TARIKH_CLUSTER8=""
MONGO_URI_HADITH_CLUSTER9=""
MONGO_URI_HADITH_CLUSTER11=""
MONGO_URI_HADITH_CLUSTER12=""

# Current configurations (Change to test different clusters)
CURRENT_MONGO_URI=${MONGO_URI_TARIKH_CLUSTER7}
CURRENT_QDRANT_URL=${QDRANT_URL}
CURRENT_QDRANT_API_KEY=${QDRANT_API_KEY}

# ========================================================
# ==================== LLM SETTINGS ======================
# ========================================================
# Google Gemini API Keys (Comma separated if multiple keys for rotation)
GOOGLE_API_KEYS="your_gemini_api_key_1,your_gemini_api_key_2"

# Model name — change to switch between Gemini models
# Options: gemini-2.0-flash | gemini-1.5-flash | gemini-2.0-flash-lite
LLM_MODEL_NAME="gemini-2.5-flash"

# Temperature — 0.0 = deterministic, 1.0 = creative
LLM_TEMPERATURE=0.0

# ========================================================
# ============== RAG PIPELINE TUNING =====================
# ========================================================
# Number of final parent documents sent to the LLM as context
RAG_SINGLE_QUERY_PARENT_TOP_K=7
RAG_MULTI_QUERY_PARENT_TOP_K=4

# Number of child chunks fetched from Qdrant (before parent expansion)
RAG_CHILD_TOP_K=20

# Multiplier for Dense/Sparse candidate fetching before RRF fusion
RAG_DENSE_MULTIPLIER=1

# RRF smoothing constant (higher = less aggressive rank fusion)
RAG_RRF_K=60

# ========================================================
# ==================== RERANKER SETTINGS =================
# ========================================================
USE_RERANKER=False
RERANKER_MODEL_NAME="BAAI/bge-reranker-v2-m3"

# The final number of child chunks sent to the LLM (works whether Reranker is True or False)
RAG_RERANKER_TOP_K=15

# ========================================================
# ==================== FALLBACK LLM SETTINGS =============
# ========================================================
FALLBACK_PROVIDER="openai"
FALLBACK_MODEL_NAME="gpt-4o-mini"
OPENAI_API_KEY="your-openai-api-key"
GROQ_API_KEY="your-groq-api-key"
