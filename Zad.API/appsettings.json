{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=ZadDb;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "AiService": {
    "BaseUrl": "https://ai-service-url",
    "TimeoutSeconds": 30,
    "ApiKey": "your-api-key"
  },
  "Jwt": {
    "Secret": "your-very-long-secret-key-minimum-32-chars",
    "Issuer": "zad-api",
    "Audience": "zad-mobile-app",
    "ExpirationMinutes": 1440
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
